# ─── Site Configuration ───
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=StepTrendy

# ─── Supabase (Database & Auth) ───
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Stripe (Payments) ───
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# ─── Stripe Price IDs ───
STRIPE_STANDARD_PRICE_ID=price_xxxxxxxx
STRIPE_PREMIUM_PRICE_ID=price_xxxxxxxx

# ─── Resend (Transactional Emails) ───
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=hello@steptrendy.com
RESEND_FROM_NAME=StepTrendy

# ─── Backend API (Development) ───
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# ─── Cloudinary (Optional - Media Storage) ───
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=xxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxx

# ─── Analytics ───
NEXT_PUBLIC_GA_ID=G-XXXXXXXX
NEXT_PUBLIC_FB_PIXEL_ID=xxxxxxxx

# ─── Deployment ───
NODE_ENV=production
